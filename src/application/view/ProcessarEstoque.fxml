<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.view.ProcessarEstoqueController">

   <children>
      <Label layoutY="25.0" style="-fx-background-color: gray;" text="                                                             Processar Estoque" textFill="WHITE" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <font><Font name="System Bold" size="14.0" /></font>
      </Label>

      <!-- Tabela de Produtos -->
      <TableView fx:id="tabProdutos" layoutY="200.0" prefHeight="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <columns>
            <TableColumn fx:id="colId" prefWidth="50" text="ID" />
            <TableColumn fx:id="colCod" prefWidth="100" text="Cód.Barras" />
            <TableColumn fx:id="colNome" prefWidth="120" text="Nome" />
            <TableColumn fx:id="colDescricao" prefWidth="140" text="Descrição" />
            <TableColumn fx:id="colCategoria" prefWidth="120" text="Categoria" />
            <TableColumn fx:id="colQuantidade" prefWidth="60" text="Qtd" />
         </columns>
      </TableView>

      <!-- Campos de Pesquisa -->
      <Label layoutX="14.0" layoutY="79.0" text="Pesquisar">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="txtPesquisar" layoutX="14.0" layoutY="98.0" prefWidth="500.0" />
      <Button fx:id="btnBuscar" layoutX="526.0" layoutY="97.0" prefHeight="26.0" prefWidth="66.0" text="Buscar" />

      <!-- Campos de Edição -->
      <TextField fx:id="txtId" layoutX="15.0" layoutY="146.0" prefWidth="50.0" />
      <Text layoutX="15.0" layoutY="142.0" text="ID"><font><Font name="System Bold" size="12.0" /></font></Text>

      <TextField fx:id="txtCod" layoutX="75.0" layoutY="146.0" prefWidth="150.0" />
      <Text layoutX="75.0" layoutY="142.0" text="Cód.Barras"><font><Font name="System Bold" size="12.0" /></font></Text>

      <TextField fx:id="txtProduto" layoutX="239.0" layoutY="146.0" prefWidth="215.0" />
      <Text layoutX="239.0" layoutY="142.0" text="Produto"><font><Font name="System Bold" size="12.0" /></font></Text>

      <TextField fx:id="txtQtd" layoutX="463.0" layoutY="146.0" prefWidth="50.0" />
      <Text layoutX="463.0" layoutY="142.0" text="Qtd"><font><Font name="System Bold" size="12.0" /></font></Text>

      <!-- Botões -->
      <Button fx:id="btnProcessar" layoutX="526.0" layoutY="146.0" text="Processar" />

      <!-- Radio Buttons -->
      <RadioButton fx:id="rbEntrada" layoutX="454.0" layoutY="61.0" selected="true" text="Entrada">
         <toggleGroup><ToggleGroup fx:id="rdOperacao" /></toggleGroup>
      </RadioButton>
      <RadioButton fx:id="rbSaida" layoutX="528.0" layoutY="61.0" text="Saída" toggleGroup="$rdOperacao" />
      <Button fx:id="btnHistorico" layoutX="375.0" layoutY="57.0" onAction="#abrirHistorico" text="Histórico">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
