<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>

<StackPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.view.MenuInicialController">

   <children>
      
      <AnchorPane prefHeight="400.0" prefWidth="600.0" />

      <MenuBar StackPane.alignment="TOP_LEFT">
        <menus>

          <Menu text="Inicio">
            <items>
              <MenuItem fx:id="itemSair" onAction="#Sair" text="Sair" />
            </items>
          </Menu>

          <Menu text="Cadastro">
            <items>
              <MenuItem fx:id="itemProduto" text="Clientes" />
              
              <MenuItem fx:id="itemCliente" onAction="#abrirCadastroProdutos" text="Produtos" />
            </items>
          </Menu>

          <Menu text="Usuario">
            <items>
              <MenuItem fx:id="itemProcessaEstoque" onAction="#abrirProcessamento" text="Processar estoque" />
            </items>
          </Menu>

        </menus>
      </MenuBar>

   </children>
</StackPane>
